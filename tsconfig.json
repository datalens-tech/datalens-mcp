{
  "extends": "@gravity-ui/tsconfig/tsconfig",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "src",
    "module": "node16",
    "moduleResolution": "node16",
    "noUnusedParameters": false,
    "noUnusedLocals": false,
    "sourceMap": true,
    "declaration": true,
    "types": ["node"]
  },
  "ts-node": {"files": true},
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
