# Base URL of the DataLens public API (required)
DATALENS_API_URL=http://localhost:8080

# Installation type, selects how requests are authorized (optional, default: cloud)
#   cloud  - fetch an IAM token via the Yandex Cloud `yc` CLI (see below)
#   yandex - send DATALENS_API_AUTH_HEADER verbatim
DATALENS_INSTALLATION=cloud

# Header for authorization, used when DATALENS_INSTALLATION=yandex (optional)
DATALENS_API_AUTH_HEADER=your-auth-header-here

# --- cloud installation only (DATALENS_INSTALLATION=cloud) ---
# Organization id, sent in the x-dl-org-id header (required for the cloud installation)
DATALENS_ORG_ID=your-org-id
# The IAM token is fetched via `yc iam create-token` on startup and refreshed on
# a timer. `yc` must be installed and authenticated where the server runs.
# `yc` profile to use (optional, defaults to the active profile)
DATALENS_YC_PROFILE=my-profile
# Path to the `yc` binary (optional, default: yc)
DATALENS_YC_BIN=yc

# URL to fetch the OpenAPI JSON schema (optional, defaults to {DATALENS_API_URL}/json/)
DATALENS_SCHEMA_URL=http://localhost:8080/json/

# API version sent with every request (optional, default: latest)
DATALENS_API_VERSION=latest

# Max characters of a command response forwarded to the client before truncation
# (optional, default: 100000). Prevents a single huge result from flooding context.
DATALENS_MAX_RESPONSE_CHARS=100000
