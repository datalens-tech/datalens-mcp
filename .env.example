# Base URL of the DataLens public API (required)
DATALENS_API_URL=http://localhost:8080

# URL to fetch the OpenAPI JSON schema
# Defaults to {DATALENS_API_URL}/json/ if not set
# DATALENS_SCHEMA_URL=http://localhost:8080/json/

# API version header sent with every request (default: latest)
# DATALENS_API_VERSION=latest

# Bearer token for authorization
# DATALENS_API_TOKEN=your-token-here

# Additional headers to send with every API request (comma-separated KEY=VALUE pairs)
# DATALENS_HEADERS=x-custom-header=value,x-another=value

# HTTP server port for the MCP endpoint (default from configs/common.yaml: 8090)
# NODE_PORT=8090
