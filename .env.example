# Organization id, sent in the x-dl-org-id header (required)
DATALENS_ORG_ID=your-org-id

# Base URL of the DataLens API
# Optional on the cloud installation (defaults to https://api.datalens.tech).
DATALENS_API_URL=http://localhost:8080

# Set to 1 or true to use DATALENS_API_AUTH_HEADER instead of the `yc` CLI (optional)
DATALENS_YC_STATIC_AUTH=1
# Static Authorization header value, used when DATALENS_YC_STATIC_AUTH is set (optional)
DATALENS_API_AUTH_HEADER=Bearer your-token

# `yc` CLI settings (used when DATALENS_YC_STATIC_AUTH is not set)
# `yc` profile to use (optional, defaults to the active profile)
DATALENS_YC_PROFILE=my-profile
# Path to the `yc` binary (optional, default: yc)
DATALENS_YC_BIN=yc

# URL to fetch the OpenAPI JSON schema (optional, defaults to {DATALENS_API_URL}/json/)
DATALENS_SCHEMA_URL=http://localhost:8080/json/

# API version sent with every request (optional, default: latest)
DATALENS_API_VERSION=latest

# Max characters of a command response forwarded to the client before truncation
# (optional, default: 100000). Prevents a single huge result from flooding context.
DATALENS_MAX_RESPONSE_CHARS=100000
